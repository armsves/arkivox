# Copy to .env and fund both addresses before running E2E:
#   npm run test:e2e:smoke   — 1 key
#   npm run test:e2e         — 2 keys (share + revoke)
#   npm run test:e2e:all     — both suites
#
# Keys required:
#   npm run test:e2e:smoke  → OWNER_PRIVATE_KEY only (1 key)
#   npm run test:e2e        → OWNER + GRANTEE (2 keys)
#
# Each wallet needs (see lib/faucets.ts — same links as demo-ctoken):
#   1. Ethereum Sepolia ETH  → bridge → Arbitrum Sepolia
#   2. USDC on Arb Sepolia (optional) — faucet.circle.com
#   3. Braga GLM — https://braga.hoodi.arkiv.network/faucet/

OWNER_PRIVATE_KEY=0x
GRANTEE_PRIVATE_KEY=0x
